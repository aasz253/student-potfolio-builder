{
  "name": "autoportfolio-builder",
  "version": "1.0.0",
  "description": "Automated developer portfolio builder with GitHub deployment",
  "main": "server/index.js",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node server/index.js",
    "client": "cd client && npm start",
    "build": "cd client && npm run build",
    "install:all": "npm install && cd client && npm install"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "mongoose": "^8.0.0",
    "octokit": "^3.1.2"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
